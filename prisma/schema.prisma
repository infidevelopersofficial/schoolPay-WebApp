// SchoolPay Database Schema
// Multi-tenant education management platform
// Phase 2: TenantType, Batch, Enrollment, Invoice, Parent portal

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// Multi-Tenant: School (Tenant Anchor)
// ============================================

model School {
  id                    String             @id @default(cuid())
  name                  String
  slug                  String             @unique
  tenantId              String?            @unique // SCH-2026-00001, CLS-2026-00001, etc.
  type                  TenantType         @default(SCHOOL) // SCHOOL, COACHING_CENTER, PRIVATE_TUTOR
  planId                String?
  plan                  Plan?              @relation(fields: [planId], references: [id])
  subscriptionStatus    SubscriptionStatus @default(TRIALING)
  currentPeriodEnd      DateTime?
  onboardingStatus      String             @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED
  onboardingStartedAt   DateTime?
  onboardingCompletedAt DateTime?

  address        String?
  city           String?
  state          String? // Place of supply for GST
  phone          String?
  email          String?
  website        String?
  logo           String?
  logoUrl        String?
  primaryColor   String   @default("#003366")
  secondaryColor String   @default("#00CCFF")
  timezone       String   @default("Asia/Kolkata")
  currency       String   @default("INR")
  gstin          String? // Goods and Services Tax Identification Number
  settings       Json? // Feature flags & preferences
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relationships
  users          UserSchool[]
  students       Student[]
  teachers       Teacher[]
  parents        Parent[]
  classes        Class[]
  batches        Batch[]
  subjects       Subject[]
  fees           Fee[]
  payments       Payment[]
  invoices       Invoice[]
  sessions       AcademicSession[]
  lessons        Lesson[]
  exams          Exam[]
  results        Result[]
  examGroups     ExamGroup[]
  gradingSchemes GradingScheme[]
  attendance     Attendance[]
  events         Event[]
  messages       Message[]
  announcements  Announcement[]
  auditLogs      AuditLog[]

  // Phase 1 relationships
  branding            SchoolBranding?
  onboardingSteps     OnboardingStep[]
  schoolSettings      SchoolSettings?
  leads               Lead[]
  testSeries          TestSeries[]
  dataImports         DataImport[]
  activityLogs        ActivityLog[]
  subscription        Subscription?
  usageRecord         UsageRecord?
  paymentTransactions PaymentTransaction[]
  tenantMetrics       TenantMetrics[]
  attendanceRegisters AttendanceRegister[]

  @@index([slug])
  @@index([type])
  @@index([tenantId])
}

enum TenantType {
  SCHOOL
  COACHING_CENTER
  PRIVATE_TUTOR
}

// ============================================
// Authentication & User Management
// ============================================

model User {
  id             String    @id @default(cuid())
  name           String
  email          String?   @unique
  phone          String?   @unique
  emailVerified  DateTime?
  hashedPassword String?
  role           Role      @default(ADMIN)
  avatar         String?
  image          String?
  isActive       Boolean   @default(true)

  // Phase 1: Session & security tracking
  lastLoginAt       DateTime?
  lastLoginIp       String?
  lastLoginDevice   String?
  passwordChangedAt DateTime?
  temporaryPassword String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relationships
  accounts    Account[]
  sessions    Session[]
  sessionLogs SessionLog[]
  auditLogs   AuditLog[]
  schools     UserSchool[]
  parent      Parent?

  // Phase 1 relationships
  activityLogs ActivityLog[]
  leads        Lead[]
  dataImports  DataImport[]

  // Phase 5A relationship
  student Student?

  @@index([email])
}

/// Join table — maps users to schools (many-to-many).
/// The `role` field is per-school so the same user can be ADMIN at one
/// school and TEACHER at another.
model UserSchool {
  id       String @id @default(cuid())
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  role     Role   @default(ADMIN)

  @@unique([userId, schoolId])
  @@index([userId])
  @@index([schoolId])
}

enum Role {
  SUPER_ADMIN
  ADMIN
  TEACHER
  PARENT
  STUDENT
}

// ============================================
// Audit & Activity Tracking
// ============================================

model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  userEmail   String?
  action      String
  entityType  String
  entityId    String
  oldValues   Json?
  newValues   Json?
  description String?
  schoolId    String?
  school      School?  @relation(fields: [schoolId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())

  @@index([entityType, entityId])
  @@index([action])
  @@index([createdAt])
  @@index([schoolId])
}

// ============================================
// Auth.js Required Models
// ============================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================
// Student Management
// ============================================

model Student {
  id String @id @default(cuid())

  // Phase 5A: Student Portal Identity
  userId          String? @unique
  user            User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  admissionNumber String?

  // Phase 5B.1: Portal Access and Security
  portalAccessEnabled   Boolean       @default(false)
  accountStatus         AccountStatus @default(PENDING_ACTIVATION)
  tempPasswordHash      String?
  tempPasswordExpiresAt DateTime?
  failedLoginAttempts   Int           @default(0)
  lockedUntil           DateTime?

  name             String
  email            String?
  phone            String?
  dateOfBirth      DateTime?
  gender           String?
  address          String?
  state            String?
  class            String
  section          String?
  rollNumber       String?
  admissionDate    DateTime?     @default(now())
  feeStatus        FeeStatus     @default(PENDING)
  totalFees        Float         @default(0)
  paidAmount       Float         @default(0)
  pendingAmount    Float         @default(0)
  bloodGroup       String?
  emergencyContact String?
  avatar           String?
  isActive         Boolean       @default(true)
  parentId         String?
  parent           Parent?       @relation(fields: [parentId], references: [id])
  leadId           String?
  schoolId         String
  school           School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  payments         Payment[]
  invoices         Invoice[]
  results          Result[]
  attendance       Attendance[]
  enrollments      Enrollment[]
  testAttempts     TestAttempt[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@unique([schoolId, admissionNumber])
  @@index([userId])
  @@index([schoolId])
  @@index([class])
  @@index([feeStatus])
}

enum AccountStatus {
  PENDING_ACTIVATION
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum FeeStatus {
  PAID
  PENDING
  OVERDUE
  PARTIAL
}

// ============================================
// Teacher Management
// ============================================

model Teacher {
  id            String    @id @default(cuid())
  name          String
  email         String
  phone         String
  subject       String
  class         String
  dateOfBirth   DateTime?
  gender        String?
  address       String?
  qualification String?
  experience    String?
  joiningDate   DateTime? @default(now())
  salary        Float?
  avatar        String?
  isActive      Boolean   @default(true)
  schoolId      String
  school        School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  lessons       Lesson[]
  exams         Exam[]
  batches       Batch[] // NEW: teacher can lead multiple batches
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([email, schoolId])
  @@index([schoolId])
  @@index([subject])
}

// ============================================
// Parent/Guardian Management
// ============================================

model Parent {
  id           String    @id @default(cuid())
  // NEW: Link to User for portal login. Nullable for existing records.
  // When a parent logs in, their User.id is stored here.
  userId       String?   @unique
  user         User?     @relation(fields: [userId], references: [id])
  name         String
  email        String
  phone        String
  relationship String?
  occupation   String?
  address      String?
  state        String?
  isActive     Boolean   @default(true)
  schoolId     String
  school       School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  students     Student[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([email, schoolId])
  @@index([schoolId])
  @@index([userId])
}

// ============================================
// Academic Structure
// ============================================

model Class {
  id           String   @id @default(cuid())
  name         String
  section      String
  strength     Int      @default(0)
  capacity     Int      @default(40)
  classTeacher String?
  room         String?
  schoolId     String
  school       School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([name, section, schoolId])
  @@index([schoolId])
}

/// Batch — the universal grouping model for all tenant types.
/// Schools:         Grade 10-A → name="Class 10-A", grade="10", section="A"
/// Coaching:        JEE Physics → name="JEE Physics Batch", subjectFocus="Physics"
/// Private Tutor:   Rohit's Math → name="Rohit - Math"
model Batch {
  id                  String               @id @default(cuid())
  name                String
  code                String?
  grade               String? // For schools: "10"
  section             String? // For schools: "A"
  subjectFocus        String? // For coaching: "JEE Physics"
  // Schedule stored as JSON: [{day: "MON", startTime: "09:00", durationMins: 90}]
  schedule            Json?
  capacity            Int                  @default(40)
  startDate           DateTime?
  endDate             DateTime?
  isActive            Boolean              @default(true)
  schoolId            String
  school              School               @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  teacherId           String?
  teacher             Teacher?             @relation(fields: [teacherId], references: [id])
  sessionId           String?
  session             AcademicSession?     @relation(fields: [sessionId], references: [id])
  enrollments         Enrollment[]
  attendances         Attendance[] // NEW: Reverse relation for batch attendance
  attendanceRegisters AttendanceRegister[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  exams               Exam[]

  @@unique([code, schoolId])
  @@index([schoolId])
  @@index([teacherId])
  @@index([sessionId])
  @@index([isActive])
}

/// Enrollment — the link between a Student and a Batch.
/// Replaces Student.class string with a proper FK relationship.
model Enrollment {
  id         String           @id @default(cuid())
  studentId  String
  student    Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  batchId    String
  batch      Batch            @relation(fields: [batchId], references: [id], onDelete: Cascade)
  status     EnrollmentStatus @default(ACTIVE)
  enrolledAt DateTime         @default(now())
  schoolId   String

  @@unique([studentId, batchId])
  @@index([schoolId])
  @@index([batchId])
  @@index([studentId])
  @@index([status])
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  DROPPED
  ON_HOLD
}

model Subject {
  id          String   @id @default(cuid())
  name        String
  code        String
  teacher     String?
  classes     Int      @default(0)
  students    Int      @default(0)
  description String?
  schoolId    String
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  exams       Exam[]

  @@unique([code, schoolId])
  @@index([schoolId])
}

// ============================================
// Financial Management — Dual Billing Mode
// Schools use Fee (structured, frequency-based)
// Coaching/Tutors use Invoice (line-item, ad-hoc)
// ============================================

model Fee {
  id          String    @id @default(cuid())
  type        String
  amount      Float
  description String
  frequency   Frequency
  dueDate     String?
  isActive    Boolean   @default(true)
  schoolId    String
  school      School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([schoolId])
}

enum Frequency {
  MONTHLY
  QUARTERLY
  YEARLY
  ONE_TIME
}

/// Invoice — flexible line-item billing for coaching centers and private tutors.
/// Each line item is stored in the `lineItems` JSON field:
/// [{description: "Monthly Tuition", qty: 1, rate: 5000, amount: 5000}]
model Invoice {
  id             String        @id @default(cuid())
  invoiceNo      String
  title          String?
  studentId      String
  student        Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  schoolId       String
  school         School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  lineItems      Json // [{description, qty, rate, amount}]
  subtotal       Float
  cgstRate       Float?        @default(0)
  cgstAmount     Float?        @default(0)
  sgstRate       Float?        @default(0)
  sgstAmount     Float?        @default(0)
  igstRate       Float?        @default(0)
  igstAmount     Float?        @default(0)
  total          Float
  discountAmount Float?        @default(0)
  discountReason String?
  dueDate        DateTime
  paidAt         DateTime?
  status         InvoiceStatus @default(DRAFT)
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@unique([invoiceNo, schoolId])
  @@index([schoolId])
  @@index([studentId])
  @@index([status])
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
}

model Payment {
  id            String        @id @default(cuid())
  studentId     String
  student       Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  amount        Float
  feeType       String
  paymentMethod PaymentMethod
  transactionId String?
  receiptNumber String?
  date          DateTime      @default(now())
  status        PaymentStatus @default(COMPLETED)
  remarks       String?
  metadata      Json? // NEW: Stores PDC details, Cheque No, Bank, EMI specifics
  schoolId      String
  school        School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@unique([receiptNumber, schoolId])
  @@index([studentId])
  @@index([date])
  @@index([status])
  @@index([schoolId])
}

enum PaymentMethod {
  CASH
  CARD
  UPI
  BANK_TRANSFER
  CHEQUE
  ONLINE
  EMI
  POST_DATED_CHEQUE
}

enum PaymentStatus {
  COMPLETED
  PENDING
  FAILED
  REFUNDED
}

// ============================================
// Academic Activities
// ============================================

model Lesson {
  id          String       @id @default(cuid())
  title       String
  subject     String
  class       String
  teacherId   String?
  teacher     Teacher?     @relation(fields: [teacherId], references: [id])
  date        String
  time        String?
  duration    String
  description String?
  status      LessonStatus @default(SCHEDULED)
  schoolId    String
  school      School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([teacherId])
  @@index([status])
  @@index([schoolId])
}

enum LessonStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

// ============================================
// Grading & Exams (Phase 6B)
// ============================================

model GradingScheme {
  id          String      @id @default(cuid())
  name        String // e.g., "Standard High School 100-point"
  description String?
  schoolId    String
  school      School      @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  bands       GradeBand[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  examGroups ExamGroup[]
}

model GradeBand {
  id              String        @id @default(cuid())
  schemeId        String
  scheme          GradingScheme @relation(fields: [schemeId], references: [id], onDelete: Cascade)
  name            String // e.g., "A+", "B"
  minMarks        Float // e.g., 90.0
  maxMarks        Float // e.g., 100.0
  points          Float? // GPA equivalent e.g., 4.0
  remarksTemplate String? // Default remarks for this band
}

model ExamGroup {
  id              String          @id @default(cuid())
  name            String // e.g. "Term 1 Finals"
  schoolId        String
  school          School          @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  sessionId       String
  session         AcademicSession @relation(fields: [sessionId], references: [id])
  gradingSchemeId String?
  gradingScheme   GradingScheme?  @relation(fields: [gradingSchemeId], references: [id])

  exams     Exam[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId])
  @@index([sessionId])
}

model Exam {
  id          String    @id @default(cuid())
  name        String
  examGroupId String
  examGroup   ExamGroup @relation(fields: [examGroupId], references: [id], onDelete: Cascade)

  batchId   String
  batch     Batch           @relation(fields: [batchId], references: [id])
  subjectId String
  subject   Subject         @relation(fields: [subjectId], references: [id])
  sessionId String
  session   AcademicSession @relation(fields: [sessionId], references: [id])

  date      String
  startTime DateTime?
  endTime   DateTime?
  maxMarks  Float

  // Locking Controls
  marksLocked      Boolean @default(false)
  resultsPublished Boolean @default(false)

  venue       String?
  description String?
  teacherId   String?
  teacher     Teacher? @relation(fields: [teacherId], references: [id])
  schoolId    String
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  results   Result[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([batchId])
  @@index([subjectId])
  @@index([sessionId])
  @@index([schoolId])
}

enum ResultStatus {
  DRAFT
  PUBLISHED
  ABSENT
  EXEMPTED
}

model Result {
  id        String          @id @default(cuid())
  examId    String
  exam      Exam            @relation(fields: [examId], references: [id], onDelete: Cascade)
  studentId String
  student   Student         @relation(fields: [studentId], references: [id], onDelete: Cascade)
  sessionId String
  session   AcademicSession @relation(fields: [sessionId], references: [id])

  status  ResultStatus @default(DRAFT)
  marks   Float? // Nullable if Absent/Exempted
  grade   String? // Derived from grading scheme
  remarks String?

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  // Auditing metadata
  enteredById String? // User ID of the teacher who entered it

  modifications GradeModificationLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([examId, studentId])
  @@index([schoolId])
  @@index([studentId])
}

model GradeModificationLog {
  id       String @id @default(cuid())
  resultId String
  result   Result @relation(fields: [resultId], references: [id], onDelete: Cascade)

  oldMarks Float?
  newMarks Float?
  oldGrade String?
  newGrade String?

  reason      String
  changedById String
  changedAt   DateTime @default(now())
}

model Attendance {
  id         String           @id @default(cuid())
  studentId  String
  student    Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  date       DateTime
  status     AttendanceStatus
  remarks    String?
  recordedBy String?
  batchId    String? // NEW: Support for batch-level attendance
  batch      Batch?           @relation(fields: [batchId], references: [id])
  schoolId   String
  school     School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@unique([studentId, date, schoolId])
  @@index([studentId])
  @@index([date])
  @@index([schoolId])
  @@index([batchId])
  @@index([schoolId, date])
  @@index([batchId, date])
  @@index([studentId, date])
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  HALF_DAY
  EXCUSED
  HOLIDAY
  LEAVE_APPROVED
  NOT_MARKED
}

enum AttendanceRegisterStatus {
  DRAFT
  SUBMITTED
  LOCKED
}

model AttendanceRegister {
  id      String   @id @default(cuid())
  date    DateTime
  batchId String
  batch   Batch    @relation(fields: [batchId], references: [id])

  status     AttendanceRegisterStatus @default(DRAFT)
  isLocked   Boolean                  @default(false)
  lockedBy   String?
  lockedAt   DateTime?
  lockReason String?

  totalStudents Int?
  presentCount  Int?
  absentCount   Int?
  lateCount     Int?

  submittedBy String?
  submittedAt DateTime?

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([batchId, date, schoolId])
  @@index([schoolId])
}

// ============================================
// Events & Communication
// ============================================

model Event {
  id          String      @id @default(cuid())
  name        String
  date        String
  time        String?
  location    String
  type        EventType
  attendees   Int         @default(0)
  description String?
  status      EventStatus @default(UPCOMING)
  schoolId    String
  school      School      @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([status])
  @@index([schoolId])
}

enum EventType {
  MEETING
  SPORTS
  ACADEMIC
  CULTURAL
  HOLIDAY
  OTHER
}

enum EventStatus {
  UPCOMING
  ONGOING
  COMPLETED
  CANCELLED
}

model Message {
  id            String   @id @default(cuid())
  from          String
  fromEmail     String
  to            String
  toEmail       String
  subject       String
  body          String   @db.Text
  unread        Boolean  @default(true)
  starred       Boolean  @default(false)
  hasAttachment Boolean  @default(false)
  schoolId      String
  school        School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([toEmail])
  @@index([unread])
  @@index([schoolId])
}

model Announcement {
  id             String               @id @default(cuid())
  title          String
  content        String               @db.Text
  date           String
  author         String
  priority       AnnouncementPriority
  category       AnnouncementCategory
  targetAudience TargetAudience
  expiryDate     String?
  isActive       Boolean              @default(true)
  schoolId       String
  school         School               @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@index([priority])
  @@index([category])
  @@index([schoolId])
}

enum AnnouncementPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum AnnouncementCategory {
  GENERAL
  ACADEMIC
  EVENT
  HOLIDAY
  EXAM
  FEE
}

enum TargetAudience {
  ALL
  STUDENTS
  TEACHERS
  PARENTS
}

// ============================================
// Academic Session / Year
// ============================================

model AcademicSession {
  id         String      @id @default(cuid())
  name       String // e.g., "2024-2025"
  startDate  DateTime
  endDate    DateTime
  isCurrent  Boolean     @default(false)
  schoolId   String
  school     School      @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  batches    Batch[]
  examGroups ExamGroup[]
  exams      Exam[]
  results    Result[]

  @@index([schoolId])
}

// ============================================
// PHASE 1: SaaS Features & Tenant Management
// ============================================

model SchoolBranding {
  id             String   @id @default(cuid())
  schoolId       String   @unique
  school         School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  logoUrl        String?
  faviconUrl     String?
  primaryColor   String
  secondaryColor String
  textColor      String
  emailTemplate  String?  @db.Text
  emailSignature String?  @db.Text
  smsSenderId    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([schoolId])
}

model OnboardingStep {
  id          String    @id @default(cuid())
  schoolId    String
  school      School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  stepKey     String // "school_details", "admin_account", "class_structure", etc.
  status      String    @default("PENDING") // PENDING, COMPLETED, SKIPPED
  data        Json? // Store step data
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([schoolId, stepKey])
  @@index([schoolId])
}

model SchoolSettings {
  id                   String   @id @default(cuid())
  schoolId             String   @unique
  school               School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  academicSessionId    String?
  defaultClassCapacity Int      @default(40)
  defaultBatchCapacity Int      @default(40)
  featureFlags         Json? // {invoicing: true, payroll: false, ...}
  notificationSettings Json? // {emailReminders: true, smsReminders: false, ...}
  currencyCode         String   @default("INR")
  decimalPlaces        Int      @default(2)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([schoolId])
}

model TenantIdCounter {
  id        String   @id @default(cuid())
  type      String // SCHOOL, COACHING_CENTER, PRIVATE_TUTOR
  year      Int
  counter   Int
  createdAt DateTime @default(now())

  @@unique([type, year])
}

model SessionLog {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  ipAddress   String
  userAgent   String?
  deviceType  String? // DESKTOP, MOBILE, TABLET
  osName      String?
  browserName String?
  location    String?
  createdAt   DateTime  @default(now())
  expiresAt   DateTime
  loggedOutAt DateTime?

  @@index([userId, createdAt])
  @@index([expiresAt])
}

model ActivityLog {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  schoolId      String?
  school        School?  @relation(fields: [schoolId], references: [id], onDelete: SetNull)
  action        String // "LOGIN", "EXPORT_DATA", "EDIT_STUDENT", etc.
  resourceType  String? // "Student", "Teacher", "Payment"
  resourceId    String?
  changes       Json? // What changed (old → new)
  ipAddress     String?
  userAgent     String?
  status        String   @default("SUCCESS") // SUCCESS, FAILURE
  failureReason String?
  createdAt     DateTime @default(now())

  @@index([userId, createdAt])
  @@index([schoolId, createdAt])
  @@index([action, resourceType])
}

model Lead {
  id                 String    @id @default(cuid())
  schoolId           String
  school             School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  name               String
  email              String
  phone              String
  source             String // WEBSITE, REFERRAL, SOCIAL_MEDIA, WALK_IN, CALL, EMAIL, ADVERTISEMENT, OTHER
  courseInterest     String? // Comma-separated: JEE,NEET,GATE
  qualification      String?
  targetExam         String?
  budget             Float?
  status             String    @default("INQUIRY") // INQUIRY, INTERESTED, DEMO_BOOKED, DEMO_COMPLETED, OFFER_SENT, NEGOTIATION, ENROLLED, PAID, LOST
  score              Int? // Auto-calculated 1-100
  assignedToId       String?
  assignedTo         User?     @relation(fields: [assignedToId], references: [id])
  notes              String?   @db.Text
  lastContactedAt    DateTime?
  nextFollowUpAt     DateTime?
  convertedStudentId String?
  convertedAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@unique([email, schoolId])
  @@index([schoolId, status])
  @@index([assignedToId])
  @@index([convertedStudentId])
}

model TestSeries {
  id                String    @id @default(cuid())
  schoolId          String
  school            School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  name              String
  course            String // JEE, NEET, GATE, SSC, CAT, etc.
  scheduleStartDate DateTime
  scheduleEndDate   DateTime?
  testCount         Int
  totalMarks        Int
  passingMarks      Int?
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  tests    TestSchedule[]
  attempts TestAttempt[]

  @@index([schoolId, course])
  @@index([isActive])
}

model TestSchedule {
  id               String     @id @default(cuid())
  seriesId         String
  series           TestSeries @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  testNumber       Int
  name             String
  scheduledOn      DateTime
  duration         Int // minutes
  totalMarks       Int
  sections         Json? // [{name, marks, questions, duration}]
  questionPaperUrl String?
  answerKeyUrl     String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  attempts TestAttempt[]

  @@unique([seriesId, testNumber])
  @@index([scheduledOn])
}

model TestAttempt {
  id                String       @id @default(cuid())
  scheduleId        String
  schedule          TestSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  seriesId          String
  series            TestSeries   @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  studentId         String
  student           Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  score             Float
  obtainedMarks     Float
  percentile        Float?
  rank              Int?
  sectionWiseScores Json? // {Physics: 80, Chemistry: 75, Maths: 90}
  completedAt       DateTime
  createdAt         DateTime     @default(now())

  @@index([scheduleId])
  @@index([seriesId])
  @@index([studentId])
  @@index([percentile])
}

model RateLimitViolation {
  id             String    @id @default(cuid())
  identifier     String // userId or IP address
  action         String // LOGIN_ATTEMPT, API_CALL, PASSWORD_RESET, etc.
  violationCount Int
  blockedUntil   DateTime?
  schoolId       String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([identifier, action])
  @@index([blockedUntil])
}

model DataImport {
  id           String    @id @default(cuid())
  schoolId     String
  school       School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdById  String
  createdBy    User      @relation(fields: [createdById], references: [id])
  entityType   String // "Student", "Teacher", "Parent"
  filename     String
  fileUrl      String
  totalRecords Int
  successCount Int       @default(0)
  errorCount   Int       @default(0)
  status       String    @default("PROCESSING") // PROCESSING, COMPLETED, FAILED
  errorLog     Json? // [{row, error, ...}]
  createdAt    DateTime  @default(now())
  completedAt  DateTime?

  @@index([schoolId, createdAt])
  @@index([status])
}

// ============================================
// SaaS Billing & Subscription (Phase 5B.3)
// ============================================

model Plan {
  id           String  @id @default(cuid())
  name         String  @unique // FREE, STARTER, GROWTH, ENTERPRISE
  description  String?
  monthlyPrice Int     @default(0) // Stored in smallest currency unit (paise)
  yearlyPrice  Int     @default(0)
  currency     String  @default("INR")

  // Operational Limits
  studentLimit   Int @default(50)
  staffLimit     Int @default(5)
  storageLimitGb Int @default(1)

  // Feature Gates (Explicit)
  studentPortal Boolean @default(false)
  parentPortal  Boolean @default(false)
  lms           Boolean @default(false)
  customDomain  Boolean @default(false)
  apiAccess     Boolean @default(false)
  whiteLabel    Boolean @default(false)

  schools       School[]
  subscriptions Subscription[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Subscription {
  id       String @id @default(cuid())
  schoolId String @unique
  school   School @relation(fields: [schoolId], references: [id])
  planId   String
  plan     Plan   @relation(fields: [planId], references: [id])

  // Normalized Billing State
  status             SubscriptionStatus @default(TRIALING)
  billingCycle       BillingCycle       @default(NONE)
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  graceEndsAt        DateTime?
  cancelAtPeriodEnd  Boolean            @default(false)

  // Provider Fields
  providerName           String  @default("RAZORPAY")
  providerSubscriptionId String? @unique
  providerCustomerId     String?

  billingEvents BillingEvent[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([status])
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  GRACE_PERIOD
  PAST_DUE
  CANCELED
  EXPIRED
}

enum BillingCycle {
  MONTHLY
  YEARLY
  NONE
}

model PaymentTransaction {
  id       String @id @default(cuid())
  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  provider               String  @default("RAZORPAY")
  razorpayPaymentId      String? @unique
  razorpayOrderId        String? @unique
  razorpaySubscriptionId String?

  amount   Decimal
  currency String        @default("INR")
  status   PaymentStatus @default(PENDING)

  failureReason    String?
  invoiceReference String?

  paidAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([schoolId])
}

model BillingWebhookEvent {
  id              String   @id @default(cuid())
  providerEventId String   @unique
  eventType       String
  isProcessed     Boolean  @default(false)
  processingError String?
  rawPayload      Json?
  processedAt     DateTime @default(now())

  @@index([providerEventId])
}

model UsageRecord {
  id               String   @id @default(cuid())
  schoolId         String   @unique
  school           School   @relation(fields: [schoolId], references: [id])
  currentStudents  Int      @default(0)
  currentStaff     Int      @default(0)
  currentStorageGb Int      @default(0)
  lastCalculatedAt DateTime @default(now())
}

model TenantMetrics {
  id             String   @id @default(cuid())
  schoolId       String
  school         School   @relation(fields: [schoolId], references: [id])
  date           DateTime // Daily snapshot date
  mrr            Int      @default(0)
  arr            Int      @default(0)
  activeStudents Int      @default(0)
  activeStaff    Int      @default(0)

  @@unique([schoolId, date])
}

model BillingEvent {
  id             String       @id @default(cuid())
  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id])
  schoolId       String
  action         String // "PAYMENT_FAILED", "LIMIT_EXCEEDED"
  amount         Int?
  description    String?
  createdAt      DateTime     @default(now())

  @@index([schoolId])
}

model DomainEvent {
  id          String    @id @default(cuid())
  eventType   String
  entityType  String
  entityId    String
  payload     Json
  createdAt   DateTime  @default(now())
  processedAt DateTime?
  schoolId    String?

  @@index([eventType])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@index([processedAt])
  @@index([schoolId])
}
