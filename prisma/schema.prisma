// SchoolPay Database Schema
// Multi-tenant school fees management system

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// Multi-Tenant: School (Tenant Anchor)
// ============================================

model School {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique // URL-safe identifier (e.g., "springfield-high")
  address   String?
  phone     String?
  email     String?
  logo      String?           // URL to school logo
  timezone  String   @default("Asia/Kolkata")
  currency  String   @default("INR")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations — every domain entity hangs off School
  users         UserSchool[]
  students      Student[]
  teachers      Teacher[]
  parents       Parent[]
  classes       Class[]
  subjects      Subject[]
  fees          Fee[]
  payments      Payment[]
  lessons       Lesson[]
  exams         Exam[]
  results       Result[]
  attendance    Attendance[]
  events        Event[]
  messages      Message[]
  announcements Announcement[]
  auditLogs     AuditLog[]

  @@index([slug])
}

// ============================================
// Authentication & User Management
// ============================================

model User {
  id             String    @id @default(cuid())
  name           String
  email          String    @unique
  emailVerified  DateTime?
  hashedPassword String?
  role           Role      @default(ADMIN)
  avatar         String?
  image          String?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  accounts  Account[]
  sessions  Session[]
  auditLogs AuditLog[]
  schools   UserSchool[]

  @@index([email])
}

/// Join table — maps users to schools (many-to-many).
/// A single user (e.g. a platform admin) can manage multiple schools.
/// The `role` field is per-school so the same user can be ADMIN at one
/// school and TEACHER at another.
model UserSchool {
  id       String @id @default(cuid())
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  role     Role   @default(ADMIN)

  @@unique([userId, schoolId])
  @@index([userId])
  @@index([schoolId])
}

enum Role {
  SUPER_ADMIN // Platform-level: can manage all schools
  ADMIN
  TEACHER
  PARENT
  STUDENT
}

// ============================================
// Audit & Activity Tracking
// ============================================

model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  userEmail   String?
  action      String
  entityType  String
  entityId    String
  oldValues   Json?
  newValues   Json?
  description String?
  schoolId    String?
  school      School?  @relation(fields: [schoolId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())

  @@index([entityType, entityId])
  @@index([action])
  @@index([createdAt])
  @@index([schoolId])
}

// ============================================
// Auth.js Required Models
// ============================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================
// Student Management
// ============================================

model Student {
  id               String      @id @default(cuid())
  name             String
  email            String
  phone            String?
  dateOfBirth      DateTime?
  gender           String?
  address          String?
  class            String
  section          String?
  rollNumber       String?
  admissionDate    DateTime?   @default(now())
  feeStatus        FeeStatus   @default(PENDING)
  totalFees        Float       @default(0)
  paidAmount       Float       @default(0)
  pendingAmount    Float       @default(0)
  bloodGroup       String?
  emergencyContact String?
  avatar           String?
  isActive         Boolean     @default(true) // Enforces Soft-Deletes preserving Payment history
  parentId         String?
  parent           Parent?     @relation(fields: [parentId], references: [id])
  schoolId         String
  school           School      @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  payments         Payment[]
  results          Result[]
  attendance       Attendance[]
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@unique([email, schoolId])
  @@index([schoolId])
  @@index([class])
  @@index([feeStatus])
}

enum FeeStatus {
  PAID
  PENDING
  OVERDUE
  PARTIAL
}

// ============================================
// Teacher Management
// ============================================

model Teacher {
  id            String    @id @default(cuid())
  name          String
  email         String
  phone         String
  subject       String
  class         String
  dateOfBirth   DateTime?
  gender        String?
  address       String?
  qualification String?
  experience    String?
  joiningDate   DateTime? @default(now())
  salary        Float?
  avatar        String?
  isActive      Boolean   @default(true)
  schoolId      String
  school        School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  lessons       Lesson[]
  exams         Exam[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([email, schoolId])
  @@index([schoolId])
  @@index([subject])
}

// ============================================
// Parent/Guardian Management
// ============================================

model Parent {
  id           String    @id @default(cuid())
  name         String
  email        String
  phone        String
  relationship String?
  occupation   String?
  address      String?
  isActive     Boolean   @default(true) // Enforces Soft-Deletes
  schoolId     String
  school       School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  students     Student[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([email, schoolId])
  @@index([schoolId])
}

// ============================================
// Academic Structure
// ============================================

model Class {
  id           String   @id @default(cuid())
  name         String
  section      String
  strength     Int      @default(0)
  capacity     Int      @default(40)
  classTeacher String?
  room         String?
  schoolId     String
  school       School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([name, section, schoolId])
  @@index([schoolId])
}

model Subject {
  id          String   @id @default(cuid())
  name        String
  code        String
  teacher     String?
  classes     Int      @default(0)
  students    Int      @default(0)
  description String?
  schoolId    String
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([code, schoolId])
  @@index([schoolId])
}

// ============================================
// Financial Management
// ============================================

model Fee {
  id          String    @id @default(cuid())
  type        String
  amount      Float
  description String
  frequency   Frequency
  dueDate     String?
  isActive    Boolean   @default(true)
  schoolId    String
  school      School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([schoolId])
}

enum Frequency {
  MONTHLY
  QUARTERLY
  YEARLY
  ONE_TIME
}

model Payment {
  id            String        @id @default(cuid())
  studentId     String
  student       Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  amount        Float
  feeType       String
  paymentMethod PaymentMethod
  transactionId String?
  receiptNumber String?       @unique
  date          DateTime      @default(now())
  status        PaymentStatus @default(COMPLETED)
  remarks       String?
  schoolId      String
  school        School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([studentId])
  @@index([date])
  @@index([status])
  @@index([schoolId])
}

enum PaymentMethod {
  CASH
  CARD
  UPI
  BANK_TRANSFER
  CHEQUE
  ONLINE
}

enum PaymentStatus {
  COMPLETED
  PENDING
  FAILED
  REFUNDED
}

// ============================================
// Academic Activities
// ============================================

model Lesson {
  id          String       @id @default(cuid())
  title       String
  subject     String
  class       String
  teacherId   String?
  teacher     Teacher?     @relation(fields: [teacherId], references: [id])
  date        String
  time        String?
  duration    String
  description String?
  status      LessonStatus @default(SCHEDULED)
  schoolId    String
  school      School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([teacherId])
  @@index([status])
  @@index([schoolId])
}

enum LessonStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

model Exam {
  id          String     @id @default(cuid())
  name        String
  subject     String
  class       String
  date        String
  time        String?
  duration    String
  maxMarks    Int
  venue       String?
  description String?
  status      ExamStatus @default(SCHEDULED)
  teacherId   String?
  teacher     Teacher?   @relation(fields: [teacherId], references: [id])
  schoolId    String
  school      School     @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  results     Result[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([teacherId])
  @@index([status])
  @@index([schoolId])
}

enum ExamStatus {
  SCHEDULED
  ONGOING
  COMPLETED
  CANCELLED
}

model Result {
  id         String       @id @default(cuid())
  studentId  String
  student    Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  examId     String?
  exam       Exam?        @relation(fields: [examId], references: [id])
  examName   String
  marks      Float
  maxMarks   Float
  grade      String
  percentage Float
  status     ResultStatus @default(PUBLISHED)
  remarks    String?
  schoolId   String
  school     School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@index([studentId])
  @@index([examId])
  @@index([schoolId])
}

enum ResultStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model Attendance {
  id        String           @id @default(cuid())
  studentId String
  student   Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  date      DateTime
  status    AttendanceStatus
  remarks   String?
  schoolId  String
  school    School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@unique([studentId, date, schoolId])
  @@index([studentId])
  @@index([date])
  @@index([schoolId])
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

// ============================================
// Events & Communication
// ============================================

model Event {
  id          String      @id @default(cuid())
  name        String
  date        String
  time        String?
  location    String
  type        EventType
  attendees   Int         @default(0)
  description String?
  status      EventStatus @default(UPCOMING)
  schoolId    String
  school      School      @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([status])
  @@index([schoolId])
}

enum EventType {
  MEETING
  SPORTS
  ACADEMIC
  CULTURAL
  HOLIDAY
  OTHER
}

enum EventStatus {
  UPCOMING
  ONGOING
  COMPLETED
  CANCELLED
}

model Message {
  id            String   @id @default(cuid())
  from          String
  fromEmail     String
  to            String
  toEmail       String
  subject       String
  body          String   @db.Text
  unread        Boolean  @default(true)
  starred       Boolean  @default(false)
  hasAttachment Boolean  @default(false)
  schoolId      String
  school        School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([toEmail])
  @@index([unread])
  @@index([schoolId])
}

model Announcement {
  id             String               @id @default(cuid())
  title          String
  content        String               @db.Text
  date           String
  author         String
  priority       AnnouncementPriority
  category       AnnouncementCategory
  targetAudience TargetAudience
  expiryDate     String?
  isActive       Boolean              @default(true)
  schoolId       String
  school         School               @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@index([priority])
  @@index([category])
  @@index([schoolId])
}

enum AnnouncementPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum AnnouncementCategory {
  GENERAL
  ACADEMIC
  EVENT
  HOLIDAY
  EXAM
  FEE
}

enum TargetAudience {
  ALL
  STUDENTS
  TEACHERS
  PARENTS
}
