// SchoolPay Database Schema
// Multi-tenant education management platform
// Phase 2: TenantType, Batch, Enrollment, Invoice, Parent portal

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================
// Multi-Tenant: School (Tenant Anchor)
// ============================================

model School {
  id         String     @id @default(cuid())
  name       String
  slug       String     @unique
  type       TenantType @default(SCHOOL)     // NEW: differentiates tenant behaviour
  plan       PlanTier   @default(FREE)       // NEW: subscription plan
  settings   Json?                           // NEW: per-tenant feature flags & preferences
  address    String?
  state      String?    // NEW: Place of supply for GST
  phone      String?
  email      String?
  logo       String?
  timezone   String     @default("Asia/Kolkata")
  currency   String     @default("INR")
  gstin      String?    // NEW: Goods and Services Tax Identification Number
  isActive   Boolean    @default(true)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  users         UserSchool[]
  students      Student[]
  teachers      Teacher[]
  parents       Parent[]
  classes       Class[]
  batches       Batch[]        // NEW
  subjects      Subject[]
  fees          Fee[]
  payments      Payment[]
  invoices      Invoice[]      // NEW
  sessions      AcademicSession[] // NEW: Academic Years
  lessons       Lesson[]
  exams         Exam[]
  results       Result[]
  attendance    Attendance[]
  events        Event[]
  messages      Message[]
  announcements Announcement[]
  auditLogs     AuditLog[]

  @@index([slug])
  @@index([type])
}

enum TenantType {
  SCHOOL
  COACHING_CENTER
  PRIVATE_TUTOR
}

enum PlanTier {
  FREE
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

// ============================================
// Authentication & User Management
// ============================================

model User {
  id             String    @id @default(cuid())
  name           String
  email          String    @unique
  phone          String?   @unique // NEW: mobile-first authentication support
  emailVerified  DateTime?
  hashedPassword String?
  role           Role      @default(ADMIN)
  avatar         String?
  image          String?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  accounts  Account[]
  sessions  Session[]
  auditLogs AuditLog[]
  schools   UserSchool[]
  parent    Parent?       // NEW: reverse link — if this user is a parent/guardian

  @@index([email])
}

/// Join table — maps users to schools (many-to-many).
/// The `role` field is per-school so the same user can be ADMIN at one
/// school and TEACHER at another.
model UserSchool {
  id       String @id @default(cuid())
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  role     Role   @default(ADMIN)

  @@unique([userId, schoolId])
  @@index([userId])
  @@index([schoolId])
}

enum Role {
  SUPER_ADMIN
  ADMIN
  TEACHER
  PARENT
  STUDENT
}

// ============================================
// Audit & Activity Tracking
// ============================================

model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  userEmail   String?
  action      String
  entityType  String
  entityId    String
  oldValues   Json?
  newValues   Json?
  description String?
  schoolId    String?
  school      School?  @relation(fields: [schoolId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())

  @@index([entityType, entityId])
  @@index([action])
  @@index([createdAt])
  @@index([schoolId])
}

// ============================================
// Auth.js Required Models
// ============================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================
// Student Management
// ============================================

model Student {
  id               String       @id @default(cuid())
  name             String
  email            String
  phone            String?
  dateOfBirth      DateTime?
  gender           String?
  address          String?
  state            String?
  class            String
  section          String?
  rollNumber       String?
  admissionDate    DateTime?    @default(now())
  feeStatus        FeeStatus    @default(PENDING)
  totalFees        Float        @default(0)
  paidAmount       Float        @default(0)
  pendingAmount    Float        @default(0)
  bloodGroup       String?
  emergencyContact String?
  avatar           String?
  isActive         Boolean      @default(true)
  parentId         String?
  parent           Parent?      @relation(fields: [parentId], references: [id])
  schoolId         String
  school           School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  payments         Payment[]
  invoices         Invoice[]    // NEW
  results          Result[]
  attendance       Attendance[]
  enrollments      Enrollment[] // NEW
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@unique([email, schoolId])
  @@index([schoolId])
  @@index([class])
  @@index([feeStatus])
}

enum FeeStatus {
  PAID
  PENDING
  OVERDUE
  PARTIAL
}

// ============================================
// Teacher Management
// ============================================

model Teacher {
  id            String    @id @default(cuid())
  name          String
  email         String
  phone         String
  subject       String
  class         String
  dateOfBirth   DateTime?
  gender        String?
  address       String?
  qualification String?
  experience    String?
  joiningDate   DateTime? @default(now())
  salary        Float?
  avatar        String?
  isActive      Boolean   @default(true)
  schoolId      String
  school        School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  lessons       Lesson[]
  exams         Exam[]
  batches       Batch[]   // NEW: teacher can lead multiple batches
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([email, schoolId])
  @@index([schoolId])
  @@index([subject])
}

// ============================================
// Parent/Guardian Management
// ============================================

model Parent {
  id           String    @id @default(cuid())
  // NEW: Link to User for portal login. Nullable for existing records.
  // When a parent logs in, their User.id is stored here.
  userId       String?   @unique
  user         User?     @relation(fields: [userId], references: [id])
  name         String
  email        String
  phone        String
  relationship String?
  occupation   String?
  address      String?
  state        String?
  isActive     Boolean   @default(true)
  schoolId     String
  school       School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  students     Student[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([email, schoolId])
  @@index([schoolId])
  @@index([userId])
}

// ============================================
// Academic Structure
// ============================================

model Class {
  id           String   @id @default(cuid())
  name         String
  section      String
  strength     Int      @default(0)
  capacity     Int      @default(40)
  classTeacher String?
  room         String?
  schoolId     String
  school       School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([name, section, schoolId])
  @@index([schoolId])
}

/// Batch — the universal grouping model for all tenant types.
/// Schools:         Grade 10-A → name="Class 10-A", grade="10", section="A"
/// Coaching:        JEE Physics → name="JEE Physics Batch", subjectFocus="Physics"
/// Private Tutor:   Rohit's Math → name="Rohit - Math"
model Batch {
  id           String       @id @default(cuid())
  name         String
  code         String?
  grade        String?      // For schools: "10"
  section      String?      // For schools: "A"
  subjectFocus String?      // For coaching: "JEE Physics"
  // Schedule stored as JSON: [{day: "MON", startTime: "09:00", durationMins: 90}]
  schedule     Json?
  capacity     Int          @default(40)
  startDate    DateTime?
  endDate      DateTime?
  isActive     Boolean      @default(true)
  schoolId     String
  school       School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  teacherId    String?
  teacher      Teacher?     @relation(fields: [teacherId], references: [id])
  enrollments  Enrollment[]
  attendances  Attendance[] // NEW: Reverse relation for batch attendance
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@unique([code, schoolId])
  @@index([schoolId])
  @@index([teacherId])
  @@index([isActive])
}

/// Enrollment — the link between a Student and a Batch.
/// Replaces Student.class string with a proper FK relationship.
model Enrollment {
  id         String           @id @default(cuid())
  studentId  String
  student    Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  batchId    String
  batch      Batch            @relation(fields: [batchId], references: [id], onDelete: Cascade)
  status     EnrollmentStatus @default(ACTIVE)
  enrolledAt DateTime         @default(now())
  schoolId   String

  @@unique([studentId, batchId])
  @@index([schoolId])
  @@index([batchId])
  @@index([studentId])
  @@index([status])
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  DROPPED
  ON_HOLD
}

model Subject {
  id          String   @id @default(cuid())
  name        String
  code        String
  teacher     String?
  classes     Int      @default(0)
  students    Int      @default(0)
  description String?
  schoolId    String
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([code, schoolId])
  @@index([schoolId])
}

// ============================================
// Financial Management — Dual Billing Mode
// Schools use Fee (structured, frequency-based)
// Coaching/Tutors use Invoice (line-item, ad-hoc)
// ============================================

model Fee {
  id          String    @id @default(cuid())
  type        String
  amount      Float
  description String
  frequency   Frequency
  dueDate     String?
  isActive    Boolean   @default(true)
  schoolId    String
  school      School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([schoolId])
}

enum Frequency {
  MONTHLY
  QUARTERLY
  YEARLY
  ONE_TIME
}

/// Invoice — flexible line-item billing for coaching centers and private tutors.
/// Each line item is stored in the `lineItems` JSON field:
/// [{description: "Monthly Tuition", qty: 1, rate: 5000, amount: 5000}]
model Invoice {
  id        String        @id @default(cuid())
  invoiceNo String
  studentId String
  student   Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  schoolId  String
  school    School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  lineItems Json          // [{description, qty, rate, amount}]
  subtotal  Float
  cgstRate  Float?        @default(0)
  cgstAmount Float?       @default(0)
  sgstRate  Float?        @default(0)
  sgstAmount Float?       @default(0)
  igstRate  Float?        @default(0)
  igstAmount Float?       @default(0)
  total     Float
  discountAmount Float?   @default(0)
  discountReason String?
  dueDate   DateTime
  paidAt    DateTime?
  status    InvoiceStatus @default(DRAFT)
  notes     String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@unique([invoiceNo, schoolId])
  @@index([schoolId])
  @@index([studentId])
  @@index([status])
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
}

model Payment {
  id            String        @id @default(cuid())
  studentId     String
  student       Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  amount        Float
  feeType       String
  paymentMethod PaymentMethod
  transactionId String?
  receiptNumber String?
  date          DateTime      @default(now())
  status        PaymentStatus @default(COMPLETED)
  remarks       String?
  metadata      Json?         // NEW: Stores PDC details, Cheque No, Bank, EMI specifics
  schoolId      String
  school        School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@unique([receiptNumber, schoolId])
  @@index([studentId])
  @@index([date])
  @@index([status])
  @@index([schoolId])
}

enum PaymentMethod {
  CASH
  CARD
  UPI
  BANK_TRANSFER
  CHEQUE
  ONLINE
  EMI
  POST_DATED_CHEQUE
}

enum PaymentStatus {
  COMPLETED
  PENDING
  FAILED
  REFUNDED
}

// ============================================
// Academic Activities
// ============================================

model Lesson {
  id          String       @id @default(cuid())
  title       String
  subject     String
  class       String
  teacherId   String?
  teacher     Teacher?     @relation(fields: [teacherId], references: [id])
  date        String
  time        String?
  duration    String
  description String?
  status      LessonStatus @default(SCHEDULED)
  schoolId    String
  school      School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([teacherId])
  @@index([status])
  @@index([schoolId])
}

enum LessonStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

model Exam {
  id          String     @id @default(cuid())
  name        String
  subject     String
  class       String
  date        String
  time        String?
  duration    String
  maxMarks    Int
  venue       String?
  description String?
  status      ExamStatus @default(SCHEDULED)
  teacherId   String?
  teacher     Teacher?   @relation(fields: [teacherId], references: [id])
  schoolId    String
  school      School     @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  results     Result[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([teacherId])
  @@index([status])
  @@index([schoolId])
}

enum ExamStatus {
  SCHEDULED
  ONGOING
  COMPLETED
  CANCELLED
}

model Result {
  id         String       @id @default(cuid())
  studentId  String
  student    Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  examId     String?
  exam       Exam?        @relation(fields: [examId], references: [id])
  examName   String
  marks      Float
  maxMarks   Float
  grade      String
  percentage Float
  status     ResultStatus @default(PUBLISHED)
  remarks    String?
  schoolId   String
  school     School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@index([studentId])
  @@index([examId])
  @@index([schoolId])
}

enum ResultStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model Attendance {
  id        String           @id @default(cuid())
  studentId String
  student   Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  date      DateTime
  status    AttendanceStatus
  remarks   String?
  batchId   String?          // NEW: Support for batch-level attendance
  batch     Batch?           @relation(fields: [batchId], references: [id])
  schoolId  String
  school    School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@unique([studentId, date, schoolId])
  @@index([studentId])
  @@index([date])
  @@index([schoolId])
  @@index([batchId])
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

// ============================================
// Events & Communication
// ============================================

model Event {
  id          String      @id @default(cuid())
  name        String
  date        String
  time        String?
  location    String
  type        EventType
  attendees   Int         @default(0)
  description String?
  status      EventStatus @default(UPCOMING)
  schoolId    String
  school      School      @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([status])
  @@index([schoolId])
}

enum EventType {
  MEETING
  SPORTS
  ACADEMIC
  CULTURAL
  HOLIDAY
  OTHER
}

enum EventStatus {
  UPCOMING
  ONGOING
  COMPLETED
  CANCELLED
}

model Message {
  id            String   @id @default(cuid())
  from          String
  fromEmail     String
  to            String
  toEmail       String
  subject       String
  body          String   @db.Text
  unread        Boolean  @default(true)
  starred       Boolean  @default(false)
  hasAttachment Boolean  @default(false)
  schoolId      String
  school        School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([toEmail])
  @@index([unread])
  @@index([schoolId])
}

model Announcement {
  id             String               @id @default(cuid())
  title          String
  content        String               @db.Text
  date           String
  author         String
  priority       AnnouncementPriority
  category       AnnouncementCategory
  targetAudience TargetAudience
  expiryDate     String?
  isActive       Boolean              @default(true)
  schoolId       String
  school         School               @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@index([priority])
  @@index([category])
  @@index([schoolId])
}

enum AnnouncementPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum AnnouncementCategory {
  GENERAL
  ACADEMIC
  EVENT
  HOLIDAY
  EXAM
  FEE
}

enum TargetAudience {
  ALL
  STUDENTS
  TEACHERS
  PARENTS
}

// ============================================
// Academic Session / Year
// ============================================

model AcademicSession {
  id        String   @id @default(cuid())
  name      String   // e.g., "2024-2025"
  startDate DateTime
  endDate   DateTime
  isCurrent Boolean  @default(false)
  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId])
}
