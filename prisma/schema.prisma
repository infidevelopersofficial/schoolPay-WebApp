generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum OnboardingStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

model School {
  id                        String                     @id @default(cuid())
  name                      String
  slug                      String                     @unique
  schoolCode                String                     @unique
  tenantId                  String?                    @unique
  type                      TenantType                 @default(SCHOOL)
  tenantType                TenantType                 @default(SCHOOL)
  isDemo                    Boolean                    @default(false)
  demoExpiresAt             DateTime?                  @default(dbgenerated("(now() + '30 days'::interval)"))
  razorpayOrderId           String?                    @unique
  planId                    String?
  subscriptionStatus        SubscriptionStatus         @default(TRIALING)
  currentPeriodEnd          DateTime?
  onboardingStatus          OnboardingStatus           @default(NOT_STARTED)
  onboardingStartedAt       DateTime?
  onboardingCompletedAt     DateTime?
  address                   String?
  city                      String?
  state                     String?
  phone                     String?
  email                     String?
  website                   String?
  logo                      String?
  logoUrl                   String?
  primaryColor              String                     @default("#003366")
  secondaryColor            String                     @default("#00CCFF")
  timezone                  String                     @default("Asia/Kolkata")
  currency                  String                     @default("INR")
  gstin                     String?
  settings                  Json?
  isActive                  Boolean                    @default(true)
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt
  sessions                  AcademicSession[]
  activityLogs              ActivityLog[]
  announcements             Announcement[]
  assignments               Assignment[]
  attendance                Attendance[]
  attendanceRegisters       AttendanceRegister[]
  auditLogs                 AuditLog[]
  automationRules           AutomationRule[]
  batches                   Batch[]
  classes                   Class[]
  communicationCampaigns    CommunicationCampaign[]
  dataImports               DataImport[]
  discountRules             DiscountRule[]
  events                    Event[]
  exams                     Exam[]
  examGroups                ExamGroup[]
  expenses                  Expense[]
  fees                      Fee[]
  feeStructures             FeeStructure[]
  feeStructureClassMappings FeeStructureClassMapping[]
  gradingSchemes            GradingScheme[]
  invoices                  Invoice[]
  invoicePenalties          InvoicePenalty[]
  leads                     Lead[]
  lessons                   Lesson[]
  messages                  Message[]
  notifications             Notification[]
  onboardingSteps           OnboardingStep[]
  parents                   Parent[]
  payments                  Payment[]
  paymentTransactions       PaymentTransaction[]
  results                   Result[]
  plan                      Plan?                      @relation(fields: [planId], references: [id])
  branding                  SchoolBranding?
  schoolSettings            SchoolSettings?
  students                  Student[]
  studentFeeMappings        StudentFeeMapping[]
  subjects                  Subject[]
  subscription              Subscription?
  surveys                   Survey[]
  teachers                  Teacher[]
  tenantMetrics             TenantMetrics[]
  testSeries                TestSeries[]
  usageRecord               UsageRecord?
  userDevices               UserDevice[]
  users                     UserSchool[]

  @@index([slug])
  @@index([type])
  @@index([tenantId])
}

model User {
  id                      String                   @id @default(cuid())
  name                    String
  email                   String?                  @unique
  phone                   String?                  @unique
  emailVerified           DateTime?
  hashedPassword          String?
  role                    Role                     @default(ADMIN)
  avatar                  String?
  image                   String?
  isActive                Boolean                  @default(true)
  lastLoginAt             DateTime?
  lastLoginIp             String?
  lastLoginDevice         String?
  passwordChangedAt       DateTime?
  temporaryPassword       String?
  failedLoginAttempts     Int                      @default(0)
  lockedUntil             DateTime?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  accounts                Account[]
  activityLogs            ActivityLog[]
  auditLogs               AuditLog[]
  campaignRecipients      CampaignRecipient[]
  campaignsCreated        CommunicationCampaign[]
  dataImports             DataImport[]
  expensesCreated         Expense[]
  leads                   Lead[]
  notificationPreferences NotificationPreference[]
  parent                  Parent?
  sessions                Session[]
  sessionLogs             SessionLog[]
  student                 Student?
  surveysCreated          Survey[]
  surveyResponses         SurveyResponse[]
  userDevices             UserDevice[]
  schools                 UserSchool[]

  @@index([email])
}

/// Join table — maps users to schools (many-to-many).
/// The `role` field is per-school so the same user can be ADMIN at one
/// school and TEACHER at another.
model UserSchool {
  id       String  @id @default(cuid())
  userId   String
  schoolId String
  role     Role    @default(ADMIN)
  staffId  String?
  school   School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, schoolId])
  @@index([userId])
  @@index([schoolId])
}

model UserDevice {
  id          String         @id @default(cuid())
  userId      String
  schoolId    String
  deviceToken String         @unique
  platform    DevicePlatform
  appVersion  String?
  deviceModel String?
  isActive    Boolean        @default(true)
  lastSeenAt  DateTime       @default(now())
  createdAt   DateTime       @default(now())
  school      School         @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([schoolId])
}

model SpayTeamUser {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("super_admin")
  createdAt DateTime @default(now())
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  userEmail   String?
  action      String
  entityType  String
  entityId    String
  oldValues   Json?
  newValues   Json?
  description String?
  schoolId    String?
  createdAt   DateTime @default(now())
  school      School?  @relation(fields: [schoolId], references: [id])
  user        User?    @relation(fields: [userId], references: [id])

  @@index([entityType, entityId])
  @@index([action])
  @@index([createdAt])
  @@index([schoolId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

model Student {
  id                    String              @id @default(cuid())
  studentId             String?             @unique
  userId                String?             @unique
  admissionNumber       String?
  portalAccessEnabled   Boolean             @default(false)
  accountStatus         AccountStatus       @default(PENDING_ACTIVATION)
  tempPasswordHash      String?
  tempPasswordExpiresAt DateTime?
  failedLoginAttempts   Int                 @default(0)
  lockedUntil           DateTime?
  name                  String
  email                 String?
  phone                 String?
  dateOfBirth           DateTime?
  gender                String?
  address               String?
  state                 String?
  class                 String
  section               String?
  rollNumber            String?
  admissionDate         DateTime?           @default(now())
  feeStatus             FeeStatus           @default(PENDING)
  totalFees             Float               @default(0)
  paidAmount            Float               @default(0)
  pendingAmount         Float               @default(0)
  bloodGroup            String?
  emergencyContact      String?
  avatar                String?
  isActive              Boolean             @default(true)
  parentId              String?
  leadId                String?
  schoolId              String
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  sessionId             String?
  attendance            Attendance[]
  discountRules         DiscountRule[]
  enrollments           Enrollment[]
  invoices              Invoice[]
  payments              Payment[]
  results               Result[]
  parent                Parent?             @relation(fields: [parentId], references: [id])
  school                School              @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  session               AcademicSession?    @relation(fields: [sessionId], references: [id])
  user                  User?               @relation(fields: [userId], references: [id])
  studentFeeMappings    StudentFeeMapping[]
  testAttempts          TestAttempt[]

  @@unique([schoolId, admissionNumber])
  @@index([userId])
  @@index([schoolId])
  @@index([class])
  @@index([feeStatus])
}

model Teacher {
  id            String    @id @default(cuid())
  name          String
  email         String
  phone         String
  subject       String
  class         String
  dateOfBirth   DateTime?
  gender        String?
  address       String?
  qualification String?
  experience    String?
  joiningDate   DateTime? @default(now())
  salary        Float?
  avatar        String?
  isActive      Boolean   @default(true)
  schoolId      String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  batches       Batch[]
  exams         Exam[]
  lessons       Lesson[]
  school        School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([email, schoolId])
  @@index([schoolId])
  @@index([subject])
}

model Parent {
  id           String    @id @default(cuid())
  userId       String?   @unique
  name         String
  email        String
  mobile       String
  relationship String?
  occupation   String?
  address      String?
  state        String?
  isActive     Boolean   @default(true)
  schoolId     String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  school       School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  user         User?     @relation(fields: [userId], references: [id])
  students     Student[]

  @@unique([email, schoolId])
  @@index([schoolId])
  @@index([userId])
}

model Class {
  id                        String                     @id @default(cuid())
  name                      String
  grade                     String?
  section                   String
  strength                  Int                        @default(0)
  capacity                  Int                        @default(40)
  classTeacher              String?
  room                      String?
  schoolId                  String
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt
  school                    School                     @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  discountRules             DiscountRule[]
  feeStructureClassMappings FeeStructureClassMapping[]

  @@unique([name, section, schoolId])
  @@index([schoolId])
}

/// Batch — the universal grouping model for all tenant types.
/// Schools:         Grade 10-A → name="Class 10-A", grade="10", section="A"
/// Coaching:        JEE Physics → name="JEE Physics Batch", subjectFocus="Physics"
/// Private Tutor:   Rohit's Math → name="Rohit - Math"
model Batch {
  id                  String               @id @default(cuid())
  name                String
  code                String?
  grade               String?
  section             String?
  subjectFocus        String?
  schedule            Json?
  capacity            Int                  @default(40)
  startDate           DateTime?
  endDate             DateTime?
  isActive            Boolean              @default(true)
  schoolId            String
  teacherId           String?
  sessionId           String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  assignments         Assignment[]
  attendances         Attendance[]
  attendanceRegisters AttendanceRegister[]
  school              School               @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  session             AcademicSession?     @relation(fields: [sessionId], references: [id])
  teacher             Teacher?             @relation(fields: [teacherId], references: [id])
  enrollments         Enrollment[]
  exams               Exam[]

  @@unique([code, schoolId])
  @@index([schoolId])
  @@index([teacherId])
  @@index([sessionId])
  @@index([isActive])
}

/// Enrollment — the link between a Student and a Batch.
/// Replaces Student.class string with a proper FK relationship.
model Enrollment {
  id         String           @id @default(cuid())
  studentId  String
  batchId    String
  status     EnrollmentStatus @default(ACTIVE)
  enrolledAt DateTime         @default(now())
  schoolId   String
  batch      Batch            @relation(fields: [batchId], references: [id], onDelete: Cascade)
  student    Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, batchId])
  @@index([schoolId])
  @@index([batchId])
  @@index([studentId])
  @@index([status])
}

model Subject {
  id          String       @id @default(cuid())
  name        String
  code        String
  teacher     String?
  classes     Int          @default(0)
  students    Int          @default(0)
  description String?
  schoolId    String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  assignments Assignment[]
  exams       Exam[]
  school      School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([code, schoolId])
  @@index([schoolId])
}

model Fee {
  id          String           @id @default(cuid())
  type        String
  amount      Float
  description String
  frequency   Frequency
  dueDate     String?
  isActive    Boolean          @default(true)
  schoolId    String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  className   String?
  sessionId   String?
  school      School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  session     AcademicSession? @relation(fields: [sessionId], references: [id])

  @@index([schoolId])
}

model FeeStructure {
  id          String                     @id @default(cuid())
  name        String
  description String?
  schoolId    String
  createdAt   DateTime                   @default(now())
  updatedAt   DateTime                   @updatedAt
  items       FeeItem[]
  school      School                     @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  mappings    FeeStructureClassMapping[]

  @@index([schoolId])
}

model FeeItem {
  id              String              @id @default(cuid())
  name            String
  amount          Int
  frequency       Frequency
  gstRate         Float?              @default(0)
  feeStructureId  String
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  feeStructure    FeeStructure        @relation(fields: [feeStructureId], references: [id], onDelete: Cascade)
  studentMappings StudentFeeMapping[]

  @@index([feeStructureId])
}

model FeeStructureClassMapping {
  id             String          @id @default(cuid())
  feeStructureId String
  classId        String
  sessionId      String
  schoolId       String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  class          Class           @relation(fields: [classId], references: [id], onDelete: Cascade)
  feeStructure   FeeStructure    @relation(fields: [feeStructureId], references: [id], onDelete: Cascade)
  school         School          @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  session        AcademicSession @relation(fields: [sessionId], references: [id])

  @@unique([feeStructureId, classId, sessionId])
  @@index([classId])
  @@index([sessionId])
  @@index([schoolId])
}

model DiscountRule {
  id        String        @id @default(cuid())
  name      String
  type      DiscountType
  value     Float
  scope     DiscountScope
  studentId String?
  classId   String?
  schoolId  String
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  class     Class?        @relation(fields: [classId], references: [id], onDelete: Cascade)
  school    School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student   Student?      @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([studentId])
  @@index([classId])
}

model StudentFeeMapping {
  id        String    @id @default(cuid())
  studentId String
  feeItemId String
  dueDate   DateTime
  amount    Int
  status    FeeStatus @default(PENDING)
  schoolId  String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  feeItem   FeeItem   @relation(fields: [feeItemId], references: [id], onDelete: Cascade)
  school    School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student   Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, feeItemId, dueDate])
  @@index([studentId])
  @@index([feeItemId])
  @@index([schoolId])
  @@index([dueDate])
  @@index([status])
}

/// Invoice — flexible line-item billing for coaching centers and private tutors.
/// Each line item is stored in the `lineItems` JSON field:
/// [{description: "Monthly Tuition", qty: 1, rate: 5000, amount: 5000}]
model Invoice {
  id             String           @id @default(cuid())
  invoiceNo      String
  title          String?
  studentId      String
  schoolId       String
  lineItems      Json
  subtotal       Float
  cgstRate       Float?           @default(0)
  cgstAmount     Float?           @default(0)
  sgstRate       Float?           @default(0)
  sgstAmount     Float?           @default(0)
  igstRate       Float?           @default(0)
  igstAmount     Float?           @default(0)
  total          Float
  discountAmount Float?           @default(0)
  discountReason String?
  dueDate        DateTime
  paidAt         DateTime?
  status         InvoiceStatus    @default(DRAFT)
  notes          String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  school         School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student        Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  penalties      InvoicePenalty[]

  @@unique([invoiceNo, schoolId])
  @@index([schoolId])
  @@index([studentId])
  @@index([status])
}

model Payment {
  id            String           @id @default(cuid())
  studentId     String
  amount        Float
  feeType       String
  paymentMethod PaymentMethod
  transactionId String?
  receiptNumber String?
  date          DateTime         @default(now())
  status        PaymentStatus    @default(COMPLETED)
  remarks       String?
  metadata      Json?
  schoolId      String
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  sessionId     String?
  school        School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  session       AcademicSession? @relation(fields: [sessionId], references: [id])
  student       Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([receiptNumber, schoolId])
  @@index([studentId])
  @@index([date])
  @@index([status])
  @@index([schoolId])
}

model Lesson {
  id          String       @id @default(cuid())
  title       String
  subject     String
  class       String
  teacherId   String?
  date        String
  time        String?
  duration    String
  description String?
  status      LessonStatus @default(SCHEDULED)
  schoolId    String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  school      School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  teacher     Teacher?     @relation(fields: [teacherId], references: [id])

  @@index([teacherId])
  @@index([status])
  @@index([schoolId])
}

model GradingScheme {
  id          String      @id @default(cuid())
  name        String
  description String?
  schoolId    String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  examGroups  ExamGroup[]
  bands       GradeBand[]
  school      School      @relation(fields: [schoolId], references: [id], onDelete: Cascade)
}

model GradeBand {
  id              String        @id @default(cuid())
  schemeId        String
  name            String
  minMarks        Float
  maxMarks        Float
  points          Float?
  remarksTemplate String?
  scheme          GradingScheme @relation(fields: [schemeId], references: [id], onDelete: Cascade)
}

model ExamGroup {
  id              String          @id @default(cuid())
  name            String
  schoolId        String
  sessionId       String
  gradingSchemeId String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  exams           Exam[]
  gradingScheme   GradingScheme?  @relation(fields: [gradingSchemeId], references: [id])
  school          School          @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  session         AcademicSession @relation(fields: [sessionId], references: [id])

  @@index([schoolId])
  @@index([sessionId])
}

model Exam {
  id               String          @id @default(cuid())
  name             String
  examGroupId      String
  batchId          String
  subjectId        String
  sessionId        String
  date             String
  startTime        DateTime?
  endTime          DateTime?
  maxMarks         Float
  marksLocked      Boolean         @default(false)
  resultsPublished Boolean         @default(false)
  venue            String?
  description      String?
  teacherId        String?
  schoolId         String
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  batch            Batch           @relation(fields: [batchId], references: [id])
  examGroup        ExamGroup       @relation(fields: [examGroupId], references: [id], onDelete: Cascade)
  school           School          @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  session          AcademicSession @relation(fields: [sessionId], references: [id])
  subject          Subject         @relation(fields: [subjectId], references: [id])
  teacher          Teacher?        @relation(fields: [teacherId], references: [id])
  results          Result[]

  @@index([batchId])
  @@index([subjectId])
  @@index([sessionId])
  @@index([schoolId])
}

model Result {
  id            String                 @id @default(cuid())
  examId        String
  studentId     String
  sessionId     String
  status        ResultStatus           @default(DRAFT)
  marks         Float?
  grade         String?
  remarks       String?
  schoolId      String
  enteredById   String?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  modifications GradeModificationLog[]
  exam          Exam                   @relation(fields: [examId], references: [id], onDelete: Cascade)
  school        School                 @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  session       AcademicSession        @relation(fields: [sessionId], references: [id])
  student       Student                @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([examId, studentId])
  @@index([schoolId])
  @@index([studentId])
}

model GradeModificationLog {
  id          String   @id @default(cuid())
  resultId    String
  oldMarks    Float?
  newMarks    Float?
  oldGrade    String?
  newGrade    String?
  reason      String
  changedById String
  changedAt   DateTime @default(now())
  result      Result   @relation(fields: [resultId], references: [id], onDelete: Cascade)
}

model Attendance {
  id         String           @id @default(cuid())
  studentId  String
  date       DateTime
  status     AttendanceStatus
  remarks    String?
  recordedBy String?
  batchId    String?
  schoolId   String
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  batch      Batch?           @relation(fields: [batchId], references: [id])
  school     School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student    Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, date, schoolId])
  @@index([studentId])
  @@index([date])
  @@index([schoolId])
  @@index([batchId])
  @@index([schoolId, date])
  @@index([batchId, date])
  @@index([studentId, date])
}

model AttendanceRegister {
  id            String                   @id @default(cuid())
  date          DateTime
  batchId       String
  status        AttendanceRegisterStatus @default(DRAFT)
  isLocked      Boolean                  @default(false)
  lockedBy      String?
  lockedAt      DateTime?
  lockReason    String?
  totalStudents Int?
  presentCount  Int?
  absentCount   Int?
  lateCount     Int?
  submittedBy   String?
  submittedAt   DateTime?
  schoolId      String
  batch         Batch                    @relation(fields: [batchId], references: [id])
  school        School                   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([batchId, date, schoolId])
  @@index([schoolId])
}

model Event {
  id          String      @id @default(cuid())
  name        String
  date        String
  time        String?
  location    String
  type        EventType
  attendees   Int         @default(0)
  description String?
  status      EventStatus @default(UPCOMING)
  schoolId    String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  school      School      @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([schoolId])
}

model Message {
  id            String   @id @default(cuid())
  from          String
  fromEmail     String
  to            String
  toEmail       String
  subject       String
  body          String
  unread        Boolean  @default(true)
  starred       Boolean  @default(false)
  hasAttachment Boolean  @default(false)
  schoolId      String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
