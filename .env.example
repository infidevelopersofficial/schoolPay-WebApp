# `.env.example` — Copy to `.env` and fill in secrets locally
# Do NOT commit your `.env` file. Keep secrets out of source control.

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api
NEXT_PUBLIC_APP_VERSION=0.0.1

# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=SCHEMA
# Docker:   postgresql://postgres:postgres@localhost:5432/schoolpay?schema=public
# Supabase: Get from project settings -> Database -> Connection string
# Neon:     Get from project dashboard
DATABASE_URL=postgresql://postgres:password@localhost:5432/schoolpay?schema=public

# ─── Authentication ───────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
# Generate: openssl rand -base64 32
AUTH_SECRET=
# Optional: encrypt server action payloads
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=

# ─── Observability ────────────────────────────────────────────────────────────

# Sentry DSN — get from https://sentry.io -> Project -> Settings -> Client Keys
NEXT_PUBLIC_SENTRY_DSN=

# Sentry release tag (set in CI to your git SHA or semver tag)
# Example: SENTRY_RELEASE=v1.2.3 or SENTRY_RELEASE=abc1234
SENTRY_RELEASE=

# Sentry organisation slug and project slug (used by sentry-webpack-plugin for source map upload)
SENTRY_ORG=schoolpay-org
SENTRY_PROJECT=schoolpay-web
# Create at https://sentry.io/settings/account/api/auth-tokens/
SENTRY_AUTH_TOKEN=

# Set to "true" to enable verbose Sentry SDK logs in development
SENTRY_DEBUG=false
NEXT_PUBLIC_SENTRY_DEBUG=false

# ─── Pino log level ───────────────────────────────────────────────────────────
# One of: trace | debug | info | warn | error | fatal  (default: info)
LOG_LEVEL=info

# ─── Performance thresholds (milliseconds) ───────────────────────────────────
# Override defaults from lib/observability/performance.ts
PERF_THRESHOLD_DB_SIMPLE=150
PERF_THRESHOLD_DB_COMPLEX=500
PERF_THRESHOLD_PAYMENT=2000
PERF_THRESHOLD_AUTH=800
PERF_THRESHOLD_EXTERNAL_API=3000
PERF_THRESHOLD_SERVER_ACTION=1000

# ─── Payments (optional — for future Stripe integration) ─────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=

# ─── Other optional public vars ───────────────────────────────────────────────
NEXT_PUBLIC_MAPS_API_KEY=
