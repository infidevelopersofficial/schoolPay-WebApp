# Production Environment Variables
# ⚠️  CRITICAL: DO NOT COMMIT THIS FILE TO GIT
# Store these securely in: CI/CD secrets, environment variables, or secrets manager

# Node environment
NODE_ENV=production

# ────────────────────────────────────────────────────────────────────────────────
# DATABASE (Neon)
# ────────────────────────────────────────────────────────────────────────────────
# Get these from: https://console.neon.tech → Project → Connection String
# DATABASE_URL: Connection pooling endpoint (for application queries)
DATABASE_URL=postgresql://[user]:[password]@[host]/[dbname]?schema=public

# DIRECT_URL: Direct connection endpoint (for migrations only)
DIRECT_URL=postgresql://[user]:[password]@[host]/[dbname]?schema=public

# ────────────────────────────────────────────────────────────────────────────────
# AUTHENTICATION (Auth.js / NextAuth)
# ────────────────────────────────────────────────────────────────────────────────
# NEXTAUTH_URL: Production domain (NO trailing slash)
NEXTAUTH_URL=https://yourdomain.com

# AUTH_SECRET: Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=

# ────────────────────────────────────────────────────────────────────────────────
# APPLICATION
# ────────────────────────────────────────────────────────────────────────────────
PORT=3000
NEXT_PUBLIC_BASE_URL=https://yourdomain.com
NEXT_PUBLIC_API_URL=https://yourdomain.com/api
NEXT_PUBLIC_APP_VERSION=1.0.0

# ────────────────────────────────────────────────────────────────────────────────
# ERROR TRACKING (Sentry)
# ────────────────────────────────────────────────────────────────────────────────
# Create Sentry project: https://sentry.io/organizations/your-org/issues/
# NEXT_PUBLIC_SENTRY_DSN: Public DSN for client-side error reporting
NEXT_PUBLIC_SENTRY_DSN=

# SENTRY_AUTH_TOKEN: For uploading source maps during build
SENTRY_AUTH_TOKEN=
SENTRY_ORG=schoolpay-org
SENTRY_PROJECT=schoolpay-web

# ────────────────────────────────────────────────────────────────────────────────
# LOGGING
# ────────────────────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ────────────────────────────────────────────────────────────────────────────────
# DATABASE TUNING (Optional)
# ────────────────────────────────────────────────────────────────────────────────
# DB_POOL_MAX: Max concurrent connections (Neon: consider tier limits)
DB_POOL_MAX=10

# DB_IDLE_TIMEOUT_MS: How long idle connections stay open
DB_IDLE_TIMEOUT_MS=30000

# DB_CONN_TIMEOUT_MS: How long to wait for a connection
DB_CONN_TIMEOUT_MS=5000
